    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": "../..",
    "paths": {
      "@game-runtime": ["packages/game-runtime/src/index.ts"],
      "@shared": ["packages/shared/src/index.ts"],
      "@ai-narrative": ["packages/ai-narrative/src/index.ts"]
    }
  },
  "include": ["src"]
}
