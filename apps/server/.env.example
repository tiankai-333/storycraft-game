# ─── Server ───────────────────────────────────────────
PORT=3001

# ─── Auth ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-64-char-hex-string
ENCRYPTION_KEY=generate-a-random-64-char-hex-string

# ─── AI Provider (used by backend proxy) ──────────────
# The server proxies AI requests — API key stays server-side.
# Set these OR use the web UI to save your key per-user.
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
