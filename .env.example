# ─── AI Provider ──────────────────────────────────────
# Used by: CLI (apps/cli), examples (packages/ai-narrative/examples)
# The CLI auto-maps DEEPSEEK_* → OPENAI_AI_KEY/AI_BASE_URL/AI_MODEL
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── AI Provider (generic, used by ai-narrative package) ──
# Alternative: set these directly if not using DeepSeek
# OPENAI_API_KEY=your-openai-api-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_MAX_TOKENS=800
# AI_TEMPERATURE=0.7

# ─── Vite client-side (VITE_ prefix required) ────────
# NOTE: These are NOT used in production — the web app proxies
# through the backend server (apps/server). Kept for legacy/dev only.
# VITE_AI_API_KEY=
# VITE_AI_BASE_URL=
# VITE_AI_MODEL=
